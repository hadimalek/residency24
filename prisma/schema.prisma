generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique @db.VarChar(191)
  passwordHash String   @db.VarChar(255)
  name         String   @db.VarChar(255)
  role         String   @default("ADMIN") @db.VarChar(20) // ADMIN | EDITOR
  createdAt    DateTime @default(now())
}

model Session {
  id           Int       @id @default(autoincrement())
  sessionKey   String    @unique @db.VarChar(191)
  language     String    @default("fa") @db.VarChar(8)
  ipAddress    String?   @db.VarChar(64)
  userAgent    String?   @db.VarChar(512)
  startedAt    DateTime  @default(now())
  lastActivity DateTime  @default(now())
  status       String    @default("ACTIVE") @db.VarChar(20) // ACTIVE | CLOSED
  messages     Message[]
  lead         Lead?

  @@index([lastActivity])
  @@index([status])
}

model Message {
  id         Int      @id @default(autoincrement())
  sessionId  Int
  role       String   @db.VarChar(20) // USER | ASSISTANT | SYSTEM
  content    String   @db.Text
  tokensUsed Int      @default(0)
  createdAt  DateTime @default(now())
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model Lead {
  id          Int      @id @default(autoincrement())
  sessionId   Int?     @unique
  name        String?  @db.VarChar(255)
  email       String?  @db.VarChar(255)
  phone       String?  @db.VarChar(32)
  nationality String?  @db.VarChar(64)
  status      String   @default("NEW") @db.VarChar(20) // NEW | FOLLOWING | CONVERTED | ARCHIVED
  createdAt   DateTime @default(now())
  session     Session? @relation(fields: [sessionId], references: [id])

  @@index([status, createdAt])
  @@index([nationality])
}

model Prompt {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  type        String   @db.VarChar(20) // SYSTEM | KNOWLEDGE
  content     String   @db.Text
  language    String   @default("fa") @db.VarChar(8) // fa | en | ar | ru
  personaName String?  @db.VarChar(120)
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type, language, isActive, sortOrder])
}

model PagePrompt {
  id            Int      @id @default(autoincrement())
  language      String   @db.VarChar(8) // fa | en | ar | ru
  pageSlug      String   @db.VarChar(191) // e.g. uae/golden-visa
  pageName      String   @db.VarChar(255)
  contextPrompt String   @db.Text
  focusKeywords String?  @db.VarChar(500)
  ctaText       String?  @db.VarChar(500)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([language, pageSlug])
  @@index([language, isActive])
}

model Provider {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(120)
  apiKey      String   @db.VarChar(255)
  model       String   @db.VarChar(100)
  baseUrl     String?  @db.VarChar(500)
  temperature Float    @default(0.7)
  maxTokens   Int      @default(1000)
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([isActive])
}
