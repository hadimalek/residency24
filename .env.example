# ============================================
# Database (MySQL — local dev via Docker)
# ============================================
# When running `npm run dev` on the host (Windows), connect via the published
# port on localhost. When the Next.js app runs *inside* the `web` container in
# docker-compose, the host is "mysql" instead — that override is set in
# docker-compose.yml and does not need to be in .env.
DATABASE_URL="mysql://residency24:CHANGE_ME_LOCAL@localhost:3306/residency24"

# Shadow database for `prisma migrate dev` (only needed locally, never in prod)
# Comment out if you don't run migrations from your laptop.
# SHADOW_DATABASE_URL="mysql://residency24:CHANGE_ME_LOCAL@localhost:3306/residency24_shadow"

# ============================================
# MySQL Docker container credentials
# (read by docker-compose.yml when starting the mysql service)
# ============================================
MYSQL_ROOT_PASSWORD="CHANGE_ME_ROOT"
MYSQL_DATABASE="residency24"
MYSQL_USER="residency24"
MYSQL_PASSWORD="CHANGE_ME_LOCAL"

# ============================================
# AI provider (used only by `prisma db seed` to populate the initial Provider
# row; the runtime chat reads keys from the Provider table, not from env).
# ============================================
OPENAI_API_KEY="your-openai-api-key"

# ============================================
# Auth
# (NEXTAUTH_* are declared for future use; current auth is custom — see
#  docs/discovery/08_FUNCTIONALITY_INVENTORY.md and Phase 1-D plan.)
# ============================================
NEXTAUTH_SECRET="change-this-to-a-random-string"
NEXTAUTH_URL="http://localhost:3000"
